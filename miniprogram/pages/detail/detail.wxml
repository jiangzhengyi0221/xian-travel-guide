<!-- pages/detail/detail.wxml -->
<view class="detail-page">
  <view class="detail-card">
    <text class="detail-card__name">{{place.name}}</text>
    <text class="detail-card__summary">{{place.summary}}</text>
    <view class="detail-card__region">
      <text class="detail-card__region-label">所属区域</text>
      <text class="detail-card__region-name">{{region.name}}</text>
    </view>

    <view class="travel-info">
      <text class="travel-info__title">游览信息</text>
      <view class="travel-info__list">
        <view class="travel-info__item">
          <text class="travel-info__label">开放时间</text>
          <text class="travel-info__content">{{place.openTime}}</text>
        </view>
        <view class="travel-info__item">
          <text class="travel-info__label">门票信息</text>
          <text class="travel-info__content">{{place.ticket}}</text>
        </view>
        <view class="travel-info__item">
          <text class="travel-info__label">建议游览时长</text>
          <text class="travel-info__content">{{place.duration}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{place.reservation}}" class="reservation-card">
      <view class="reservation-card__header">
        <text class="reservation-card__title">预约信息</text>
        <text class="reservation-card__status reservation-card__status--{{place.reservation.status}}">
          {{place.reservation.statusText}}
        </text>
      </view>
      <text class="reservation-card__platform">{{place.reservation.platform}}</text>
      <text class="reservation-card__instructions">{{place.reservation.instructions}}</text>
      <button
        wx:if="{{hasReservationAction}}"
        class="reservation-button"
        bindtap="openReservation"
      >预约参观</button>
      <view class="reservation-card__source">
        <text>官方来源：{{place.reservation.sourceName}}</text>
        <text>核实日期：{{place.reservation.verifiedAt}}</text>
      </view>
    </view>

    <view class="detail-section detail-section--description">
      <text class="detail-section__title">详细介绍</text>
      <text class="detail-section__description">{{place.description}}</text>
    </view>

    <view class="detail-section">
      <text class="detail-section__title">地址</text>
      <text class="detail-section__content">{{place.address}}</text>
      <navigator
        wx:if="{{hasLocation}}"
        class="reference-location-button"
        url="/pages/place-map/place-map?id={{place.id}}"
      >📍查看参考位置</navigator>
      <view
        wx:if="{{hasLocation}}"
        class="reference-location-button"
        bindtap="openNavigation"
      >打开地图导航</view>
    </view>

    <view class="detail-section">
      <text class="detail-section__title">推荐理由</text>
      <text class="detail-section__content">{{place.recommend}}</text>
    </view>

    <view class="detail-section">
      <text class="detail-section__title">地点标签</text>
      <view class="tag-list">
        <text
          wx:for="{{place.tags}}"
          wx:key="*this"
          class="tag-item"
        >{{item}}</text>
      </view>
    </view>

    <view class="detail-section">
      <text class="detail-section__title">实用提醒</text>
      <view class="tip-list">
        <view
          wx:for="{{place.notice}}"
          wx:key="*this"
          class="tip-item"
        >
          <text class="tip-item__marker">•</text>
          <text class="tip-item__text">{{item}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
