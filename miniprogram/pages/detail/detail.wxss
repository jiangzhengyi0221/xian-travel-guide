/* pages/detail/detail.wxss */
page {
  min-height: 100%;
  background: #f7f3ea;
  color: #27231f;
}

.detail-page {
  padding: 48rpx 32rpx;
}

.detail-card {
  display: flex;
  flex-direction: column;
  padding: 40rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(76, 58, 36, 0.08);
}

.detail-card__name {
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.3;
}

.detail-card__summary {
  margin-top: 16rpx;
  color: #756d63;
  font-size: 26rpx;
  line-height: 1.7;
}

.detail-card__region {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
}

.detail-card__region-label {
  margin-right: 14rpx;
  color: #948a7e;
  font-size: 22rpx;
}

.detail-card__region-name {
  padding: 7rpx 16rpx;
  border-radius: 18rpx;
  background: #eee5d6;
  color: #685846;
  font-size: 21rpx;
  font-weight: 600;
}

.detail-section {
  display: flex;
  flex-direction: column;
  margin-top: 40rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid rgba(109, 91, 69, 0.12);
}

.detail-section__title {
  color: #a24b32;
  font-size: 24rpx;
  font-weight: 650;
}

.detail-section__content {
  margin-top: 14rpx;
  color: #4f4942;
  font-size: 27rpx;
  line-height: 1.7;
}

.detail-section--description {
  margin-top: 44rpx;
}

.detail-section__description {
  margin-top: 18rpx;
  color: #4f4942;
  font-size: 27rpx;
  line-height: 1.9;
  text-align: justify;
  white-space: pre-wrap;
  word-break: break-all;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.tag-item {
  padding: 9rpx 18rpx;
  border-radius: 20rpx;
  background: #eee5d6;
  color: #685846;
  font-size: 21rpx;
}

.tip-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
}

.tip-item__marker {
  width: 30rpx;
  flex: none;
  color: #a24b32;
  font-size: 28rpx;
  line-height: 1.6;
}

.tip-item__text {
  flex: 1;
  color: #5e574f;
  font-size: 25rpx;
  line-height: 1.6;
}
