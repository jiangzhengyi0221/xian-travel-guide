<!-- pages/food/food.wxml -->
<view class="food-page">
  <view class="hero">
    <text class="hero__eyebrow">XI'AN FOOD GUIDE</text>
    <block wx:if="{{hasSelectedRegion}}">
      <text class="hero__title">{{region.name}}美食</text>
      <text class="hero__subtitle">{{foods.length}} 种区域风味，慢慢品尝古城烟火</text>
    </block>
    <block wx:else>
      <text class="hero__title">西安美食</text>
      <text class="hero__subtitle">选择旅行区域，发现沿途的本地味道</text>
    </block>
  </view>

  <view class="region-picker" wx:if="{{!hasSelectedRegion}}">
    <view class="region-picker__heading">
      <text class="region-picker__title">{{regionNotFound ? '未找到该区域' : '选择美食区域'}}</text>
      <text class="region-picker__hint">以下区域已有美食内容</text>
    </view>

    <view class="region-picker__list">
      <view
        class="region-picker__item region-picker__item--theme-{{index % 5}}"
        wx:for="{{foodRegions}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="selectRegion"
      >
        <view class="region-picker__text">
          <text class="region-picker__name">{{item.name}}</text>
          <text class="region-picker__summary">{{item.summary}}</text>
          <text class="region-picker__count">{{item.foodCount}} 种美食</text>
        </view>
        <text class="region-picker__arrow">→</text>
      </view>
    </view>
  </view>

  <block wx:if="{{hasSelectedRegion}}">
    <view class="food-list" wx:if="{{foods.length}}">
      <view
        class="food-card food-card--theme-{{index % 5}}"
        wx:for="{{foods}}"
        wx:key="id"
      >
        <image
          wx:if="{{item.image}}"
          class="food-card__image"
          src="{{item.image}}"
          mode="aspectFill"
        ></image>
        <view wx:else class="food-card__image-placeholder">
          <text class="food-card__placeholder-icon">食</text>
          <text class="food-card__placeholder-text">图片待添加</text>
        </view>

        <view class="food-card__body">
          <view class="food-card__heading">
            <view class="food-card__title-group">
              <text class="food-card__type">{{item.type}}</text>
              <text class="food-card__name">{{item.name}}</text>
            </view>
            <text class="food-card__price">{{item.price}}</text>
          </view>

          <view class="food-card__shop-row">
            <text class="food-card__label">推荐店铺</text>
            <text class="food-card__shop">{{item.shop}}</text>
          </view>

          <text class="food-card__summary">{{item.summary}}</text>

          <view class="food-card__address-row">
            <text class="food-card__address-icon">⌖</text>
            <text class="food-card__address">{{item.address}}</text>
          </view>

          <view class="food-card__tags">
            <text
              class="food-card__tag"
              wx:for="{{item.tags}}"
              wx:for-item="tag"
              wx:key="*this"
            >{{tag}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <text class="empty-state__title">该区域暂无美食内容</text>
      <text class="empty-state__description">美食资料整理好后会显示在这里</text>
    </view>
  </block>
</view>
