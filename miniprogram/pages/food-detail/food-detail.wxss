/* pages/food-detail/food-detail.wxss */
page {
  min-height: 100%;
  background: #f7f3ea;
  color: #27231f;
}

.food-detail-page {
  padding: 48rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
}

.detail-card {
  display: flex;
  flex-direction: column;
  padding: 40rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(76, 58, 36, 0.08);
}

.detail-card__heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.detail-card__type {
  color: #a24b32;
  font-size: 22rpx;
  font-weight: 650;
}

.detail-card__price {
  flex: none;
  padding: 8rpx 16rpx;
  border-radius: 18rpx;
  background: #dce4d2;
  color: #536348;
  font-size: 21rpx;
  font-weight: 600;
}

.detail-card__name {
  margin-top: 18rpx;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.3;
}

.detail-card__summary {
  margin-top: 16rpx;
  color: #756d63;
  font-size: 26rpx;
  line-height: 1.7;
}

.detail-card__region {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
}

.detail-card__region-label {
  margin-right: 14rpx;
  color: #948a7e;
  font-size: 22rpx;
}

.detail-card__region-name {
  padding: 7rpx 16rpx;
  border-radius: 18rpx;
  background: #eee5d6;
  color: #685846;
  font-size: 21rpx;
  font-weight: 600;
}

.food-image,
.food-image-placeholder {
  width: 100%;
  height: 320rpx;
  margin-top: 32rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.food-image-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #edf1e8;
  color: #66705c;
}

.food-image-placeholder__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.72);
  font-size: 38rpx;
  font-weight: 700;
}

.food-image-placeholder__text {
  margin-top: 16rpx;
  font-size: 22rpx;
}

.detail-section {
  display: flex;
  flex-direction: column;
  margin-top: 40rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid rgba(109, 91, 69, 0.12);
}

.detail-section--description {
  margin-top: 44rpx;
}

.detail-section__title {
  color: #a24b32;
  font-size: 24rpx;
  font-weight: 650;
}

.detail-section__content {
  margin-top: 14rpx;
  color: #4f4942;
  font-size: 27rpx;
  line-height: 1.7;
}

.detail-section__description {
  margin-top: 18rpx;
  color: #4f4942;
  font-size: 27rpx;
  line-height: 1.9;
  text-align: justify;
  white-space: pre-wrap;
  word-break: break-all;
}

.reference-location-button {
  display: flex;
  align-items: center;
  align-self: flex-start;
  justify-content: center;
  min-height: 72rpx;
  margin-top: 22rpx;
  padding: 0 28rpx;
  border-radius: 36rpx;
  background: #a24b32;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.4;
  box-shadow: 0 10rpx 28rpx rgba(113, 49, 31, 0.2);
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.tag-item {
  padding: 9rpx 18rpx;
  border-radius: 20rpx;
  background: #edf1e8;
  color: #59654f;
  font-size: 21rpx;
}

.tip-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
}

.tip-item__marker {
  width: 30rpx;
  flex: none;
  color: #a24b32;
  font-size: 28rpx;
  line-height: 1.6;
}

.tip-item__text {
  flex: 1;
  color: #5e574f;
  font-size: 25rpx;
  line-height: 1.6;
}

.error-state {
  display: flex;
  min-height: 420rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 36rpx;
  border: 2rpx dashed rgba(109, 91, 69, 0.24);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.64);
  box-sizing: border-box;
  text-align: center;
}

.error-state__title {
  color: #665a4d;
  font-size: 32rpx;
  font-weight: 650;
}

.error-state__description {
  margin-top: 16rpx;
  color: #948a7e;
  font-size: 24rpx;
  line-height: 1.7;
}
