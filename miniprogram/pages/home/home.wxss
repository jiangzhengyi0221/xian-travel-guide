/* pages/home/home.wxss */
page {
  min-height: 100%;
  background: #f7f3ea;
  color: #27231f;
}

.home-page {
  padding: 48rpx 32rpx calc(56rpx + env(safe-area-inset-bottom));
}

.hero {
  display: flex;
  flex-direction: column;
  padding: 16rpx 8rpx 48rpx;
}

.hero__eyebrow {
  color: #a24b32;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.hero__title {
  margin-top: 12rpx;
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: 4rpx;
}

.hero__subtitle {
  margin-top: 14rpx;
  color: #756d63;
  font-size: 28rpx;
  line-height: 1.6;
}

.section {
  margin-bottom: 48rpx;
}

.section-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 22rpx;
  padding: 0 8rpx;
}

.section-heading__title {
  font-size: 36rpx;
  font-weight: 650;
}

.section-heading__hint {
  color: #948a7e;
  font-size: 22rpx;
}

.map-placeholder {
  position: relative;
  height: 480rpx;
  overflow: hidden;
  border: 2rpx solid rgba(125, 97, 64, 0.16);
  border-radius: 32rpx;
  background:
    linear-gradient(rgba(255, 255, 255, 0.16) 2rpx, transparent 2rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.16) 2rpx, transparent 2rpx),
    #d9cdb6;
  background-size: 56rpx 56rpx;
  box-shadow: 0 18rpx 50rpx rgba(76, 58, 36, 0.12);
}

.map-placeholder__ring {
  position: absolute;
  border: 2rpx dashed rgba(103, 79, 51, 0.25);
  border-radius: 50%;
}

.map-placeholder__ring--large {
  top: 60rpx;
  left: 90rpx;
  width: 440rpx;
  height: 320rpx;
  transform: rotate(-10deg);
}

.map-placeholder__ring--small {
  top: 140rpx;
  left: 240rpx;
  width: 230rpx;
  height: 190rpx;
  transform: rotate(15deg);
}

.map-placeholder__label {
  position: absolute;
  right: 24rpx;
  bottom: 20rpx;
  color: rgba(71, 56, 38, 0.55);
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.map-region-list {
  position: absolute;
  z-index: 1;
  top: 76rpx;
  right: 36rpx;
  bottom: 64rpx;
  left: 36rpx;
  display: flex;
  flex-wrap: wrap;
  align-content: center;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
}

.map-region {
  min-width: 150rpx;
  height: 68rpx;
  margin: 0;
  padding: 0 22rpx;
  border: 0;
  border-radius: 34rpx;
  background: #fffaf0;
  color: #55442f;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 68rpx;
  box-shadow: 0 8rpx 24rpx rgba(76, 58, 36, 0.18);
}

.map-region::after {
  border: 0;
}

.region-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.region-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 144rpx;
  padding: 28rpx 30rpx;
  border-radius: 28rpx;
  box-sizing: border-box;
}

.region-card--theme-0,
.map-region--theme-0 {
  background: #ead8c0;
}

.region-card--theme-1,
.map-region--theme-1 {
  background: #dce4d2;
}

.region-card--theme-2,
.map-region--theme-2 {
  background: #e5d7d1;
}

.region-card--theme-3,
.map-region--theme-3 {
  background: #d9dee8;
}

.region-card--theme-4,
.map-region--theme-4 {
  background: #dbc9b7;
}

.region-card__content {
  display: flex;
  flex: 1;
  align-items: center;
  min-width: 0;
}

.region-card__index {
  width: 64rpx;
  color: rgba(66, 53, 38, 0.46);
  font-size: 22rpx;
  font-weight: 600;
}

.region-card__text {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.region-card__name {
  font-size: 32rpx;
  font-weight: 650;
}

.region-card__description {
  margin-top: 8rpx;
  color: #71685e;
  font-size: 23rpx;
}

.region-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.region-card__tag {
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.42);
  color: #685d50;
  font-size: 19rpx;
  line-height: 1.2;
}

.region-card__arrow,
.itinerary-entry__arrow {
  flex: none;
  font-size: 38rpx;
  font-weight: 300;
}

.itinerary-entry {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-radius: 30rpx;
  background: #9f4a32;
  color: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(113, 49, 31, 0.24);
}

.itinerary-entry__icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  flex: none;
  border: 2rpx solid rgba(255, 255, 255, 0.42);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.12);
  font-size: 25rpx;
  font-weight: 600;
}

.itinerary-entry__text {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-width: 0;
  margin-left: 24rpx;
}

.itinerary-entry__title {
  font-size: 32rpx;
  font-weight: 650;
}

.itinerary-entry__description {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 22rpx;
}

.itinerary-entry__arrow {
  margin-left: 16rpx;
}
