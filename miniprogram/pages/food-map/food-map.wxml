<!-- pages/food-map/food-map.wxml -->
<view class="food-map-page">
  <view wx:if="{{locationNotFound}}" class="error-state">
    <text class="error-state__title">未找到参考位置</text>
    <text class="error-state__description">该美食暂时没有有效的参考位置，请返回详情页继续浏览。</text>
  </view>

  <block wx:else>
    <view class="location-card">
      <text class="location-card__eyebrow">REFERENCE LOCATION</text>
      <text class="location-card__title">{{food.name}}</text>

      <view class="location-card__item">
        <text class="location-card__label">推荐店铺</text>
        <text class="location-card__content">{{food.shop}}</text>
      </view>

      <view class="location-card__item">
        <text class="location-card__label">地址</text>
        <text class="location-card__content">{{food.address}}</text>
      </view>
    </view>

    <view class="map-frame">
      <map
        class="food-map"
        latitude="{{mapLatitude}}"
        longitude="{{mapLongitude}}"
        scale="{{mapScale}}"
        markers="{{markers}}"
        bindmarkertap="goBackToFoodDetail"
      ></map>
    </view>

    <view class="reference-notice">
      <text class="reference-notice__title">参考位置说明</text>
      <text class="reference-notice__content">该位置仅供旅行参考，实际门店信息请以商家最新情况为准。</text>
    </view>
  </block>
</view>
