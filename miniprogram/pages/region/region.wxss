/* pages/region/region.wxss */
page {
  min-height: 100%;
  background: #f7f3ea;
  color: #27231f;
}

.region-page {
  padding: 48rpx 32rpx calc(56rpx + env(safe-area-inset-bottom));
}

.region-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 52rpx;
  padding: 16rpx 8rpx 40rpx;
  border-bottom: 2rpx solid rgba(94, 75, 52, 0.14);
}

.region-header__eyebrow {
  color: #a24b32;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.region-header__title {
  margin-top: 12rpx;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: 2rpx;
}

.region-header__summary {
  margin-top: 16rpx;
  color: #756d63;
  font-size: 27rpx;
  line-height: 1.7;
}

.search-entry {
  display: flex;
  align-items: center;
  margin-bottom: 36rpx;
  padding: 24rpx 28rpx;
  border: 2rpx solid rgba(109, 91, 69, 0.14);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.7);
  box-shadow: 0 10rpx 30rpx rgba(76, 58, 36, 0.08);
}

.search-entry--pressed {
  opacity: 0.72;
}

.search-entry__icon {
  flex: none;
  color: #a24b32;
  font-size: 44rpx;
  line-height: 1;
}

.search-entry__text {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  margin-left: 20rpx;
}

.search-entry__title {
  color: #3f3831;
  font-size: 28rpx;
  font-weight: 650;
}

.search-entry__hint {
  margin-top: 6rpx;
  color: #948a7e;
  font-size: 21rpx;
}

.search-entry__arrow {
  flex: none;
  margin-left: 18rpx;
  color: #756d63;
  font-size: 36rpx;
  font-weight: 300;
}

.region-search {
  margin-bottom: 36rpx;
}

.region-search__form {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.region-search__input {
  height: 84rpx;
  min-width: 0;
  flex: 1;
  padding: 0 26rpx;
  border: 2rpx solid rgba(109, 91, 69, 0.16);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.82);
  box-sizing: border-box;
  color: #302a25;
  font-size: 27rpx;
}

.region-search__placeholder {
  color: #9a9187;
}

.region-search__cancel {
  display: flex;
  height: 84rpx;
  flex: none;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  color: #8b442f;
  font-size: 25rpx;
  font-weight: 600;
}

.region-suggestion-panel {
  overflow: hidden;
  margin-top: 16rpx;
  border: 2rpx solid rgba(109, 91, 69, 0.14);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 16rpx 42rpx rgba(76, 58, 36, 0.12);
}

.region-suggestion-list {
  display: flex;
  flex-direction: column;
}

.region-suggestion-item {
  display: flex;
  align-items: center;
  min-height: 92rpx;
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid rgba(109, 91, 69, 0.09);
  box-sizing: border-box;
}

.region-suggestion-item:last-child {
  border-bottom: 0;
}

.region-suggestion-item--pressed {
  background: rgba(238, 229, 214, 0.7);
}

.region-suggestion-item__type {
  width: 126rpx;
  flex: none;
  color: #7b6a58;
  font-size: 22rpx;
}

.region-suggestion-item__name {
  min-width: 0;
  flex: 1;
  color: #302a25;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.45;
}

.region-suggestion-item__arrow {
  flex: none;
  margin-left: 16rpx;
  color: #948a7e;
  font-size: 32rpx;
  font-weight: 300;
}

.region-suggestion-empty {
  padding: 30rpx 24rpx;
  color: #857a6e;
  font-size: 23rpx;
  text-align: center;
}

.place-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.place-card {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  border: 2rpx solid rgba(109, 91, 69, 0.12);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.64);
  box-shadow: 0 12rpx 36rpx rgba(76, 58, 36, 0.08);
}

.place-card__name {
  font-size: 32rpx;
  font-weight: 650;
}

.place-card__summary {
  margin-top: 12rpx;
  color: #756d63;
  font-size: 24rpx;
  line-height: 1.65;
}

.place-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.place-card__tag {
  padding: 8rpx 16rpx;
  border-radius: 18rpx;
  background: #eee5d6;
  color: #685846;
  font-size: 20rpx;
  line-height: 1.2;
}

.food-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.food-card {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  border: 2rpx solid rgba(91, 109, 76, 0.12);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.64);
  box-shadow: 0 12rpx 36rpx rgba(76, 58, 36, 0.08);
}

.food-card__image {
  width: 100%;
  height: 240rpx;
  margin-bottom: 24rpx;
  border-radius: 20rpx;
}

.food-card__heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.food-card__name {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 650;
  line-height: 1.4;
}

.food-card__price {
  flex: none;
  padding: 7rpx 14rpx;
  border-radius: 16rpx;
  background: #dce4d2;
  color: #536348;
  font-size: 20rpx;
  font-weight: 600;
}

.food-card__shop-row {
  display: flex;
  align-items: flex-start;
  margin-top: 16rpx;
}

.food-card__shop-label {
  flex: none;
  margin-right: 12rpx;
  color: #a24b32;
  font-size: 21rpx;
  font-weight: 600;
  line-height: 1.6;
}

.food-card__shop {
  color: #514a42;
  font-size: 23rpx;
  line-height: 1.6;
}

.food-card__summary {
  margin-top: 12rpx;
  color: #756d63;
  font-size: 24rpx;
  line-height: 1.65;
}

.food-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.food-card__tag {
  padding: 8rpx 16rpx;
  border-radius: 18rpx;
  background: #edf1e8;
  color: #59654f;
  font-size: 20rpx;
  line-height: 1.2;
}

.content-section {
  margin-bottom: 44rpx;
}

.content-section__heading {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 16rpx;
  border: 2rpx solid transparent;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.36);
}

.content-section__heading--active {
  border-color: rgba(109, 91, 69, 0.12);
  background: rgba(255, 255, 255, 0.72);
}

.content-section__heading--pressed {
  opacity: 0.72;
}

.content-section__number {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  flex: none;
  border-radius: 20rpx;
  color: #584c3e;
  font-size: 21rpx;
  font-weight: 650;
}

.content-section--attraction .content-section__number {
  background: #ead8c0;
}

.content-section--food .content-section__number {
  background: #dce4d2;
}

.content-section__text {
  display: flex;
  min-width: 0;
  flex: 1;
  flex-direction: column;
  margin-left: 20rpx;
}

.content-section__title-row {
  display: flex;
  align-items: center;
}

.content-section__indicator {
  width: 30rpx;
  margin-right: 10rpx;
  color: #a24b32;
  font-size: 22rpx;
  line-height: 1;
  text-align: center;
}

.content-section__title {
  font-size: 34rpx;
  font-weight: 650;
}

.content-section__subtitle {
  margin-top: 4rpx;
  color: #948a7e;
  font-size: 22rpx;
}

.content-placeholder {
  display: flex;
  min-height: 180rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed rgba(109, 91, 69, 0.24);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.42);
  box-sizing: border-box;
}

.content-placeholder__label {
  color: #665a4d;
  font-size: 27rpx;
  font-weight: 600;
}

.content-placeholder__hint {
  margin-top: 10rpx;
  color: #9a9187;
  font-size: 22rpx;
}
