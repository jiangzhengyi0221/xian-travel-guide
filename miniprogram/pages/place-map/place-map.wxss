/* pages/place-map/place-map.wxss */
page {
  min-height: 100%;
  background: #f7f3ea;
  color: #27231f;
}

.place-map-page {
  padding: 48rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
}

.location-card {
  display: flex;
  flex-direction: column;
  padding: 36rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(76, 58, 36, 0.08);
}

.location-card__eyebrow {
  color: #a24b32;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 3rpx;
}

.location-card__title {
  margin-top: 12rpx;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.35;
}

.location-card__item {
  display: flex;
  align-items: flex-start;
  margin-top: 26rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(109, 91, 69, 0.12);
}

.location-card__label {
  width: 132rpx;
  flex: none;
  color: #948a7e;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.65;
}

.location-card__content {
  flex: 1;
  color: #514a42;
  font-size: 25rpx;
  line-height: 1.65;
}

.map-frame {
  height: 620rpx;
  margin-top: 28rpx;
  overflow: hidden;
  border: 2rpx solid rgba(125, 97, 64, 0.16);
  border-radius: 28rpx;
  background: #d9cdb6;
  box-shadow: 0 14rpx 40rpx rgba(76, 58, 36, 0.1);
}

.place-map {
  width: 100%;
  height: 100%;
}

.reference-notice {
  display: flex;
  flex-direction: column;
  margin-top: 28rpx;
  padding: 28rpx 30rpx;
  border-left: 6rpx solid #a24b32;
  border-radius: 20rpx;
  background: #eee5d6;
}

.reference-notice__title {
  color: #685846;
  font-size: 23rpx;
  font-weight: 650;
}

.reference-notice__content {
  margin-top: 10rpx;
  color: #756d63;
  font-size: 23rpx;
  line-height: 1.7;
}

.error-state {
  display: flex;
  min-height: 420rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 36rpx;
  border: 2rpx dashed rgba(109, 91, 69, 0.24);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.64);
  box-sizing: border-box;
  text-align: center;
}

.error-state__title {
  color: #665a4d;
  font-size: 32rpx;
  font-weight: 650;
}

.error-state__description {
  margin-top: 16rpx;
  color: #948a7e;
  font-size: 24rpx;
  line-height: 1.7;
}
